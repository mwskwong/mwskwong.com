{
  "extends": ["@tsconfig/bases/strictest", "@tsconfig/bases/next"],
  "compilerOptions": {
    "noPropertyAccessFromIndexSignature": false, // conflict with @typescript-eslint/no-non-null-asserted-optional-chain
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ]
}
