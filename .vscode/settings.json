{
  // CSS Variable Autocomplete with Mantine
  "cssVariables.lookupFiles": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "**/*.less",
    "node_modules/@mantine/core/styles.css"
  ],

  // Stylelint
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,

  // fix auto-fixable problems found by Prettier, ESlint and Stylelint on save, in this particular order
  "editor.codeActionsOnSave": {
    "source.fixAll.prettier": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },

  // Prettier
  "editor.defaultFormatter": "esbenp.prettier-vscode"
}
